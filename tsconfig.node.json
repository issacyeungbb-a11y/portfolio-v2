{
  "compilerOptions": {
    "composite": true,
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "types": ["node", "vite/client"]
  },
  "include": [
    "vite.config.ts",
    "src/lib/api/**/*.ts",
    "src/lib/firebase/**/*.ts",
    "server/**/*.ts",
    "src/types/**/*.ts"
  ]
}
