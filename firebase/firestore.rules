rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /portfolio/{portfolioId} {
      allow read, create, update: if true;
      allow delete: if false;

      match /assets/{assetId} {
        allow read, create, update: if true;
        allow delete: if true;

        match /priceHistory/{entryId} {
          allow read, create, update: if true;
          allow delete: if false;
        }
      }

      match /priceUpdateReviews/{assetId} {
        allow read, create, update: if true;
        allow delete: if false;
      }

      match /analysisCache/{snapshotHash} {
        allow read, create, update: if true;
        allow delete: if false;
      }

      match /analysisSessions/{sessionId} {
        allow read, create, update: if true;
        allow delete: if false;
      }

      match /analysisSettings/{settingId} {
        allow read, create, update: if true;
        allow delete: if false;
      }

      match /portfolioSnapshots/{snapshotId} {
        allow read, create, update: if true;
        allow delete: if false;
      }

      match /accountPrincipals/{accountSource} {
        allow read, create, update: if true;
        allow delete: if false;
      }

      match /accountCashFlows/{entryId} {
        allow read, create, update: if true;
        allow delete: if false;
      }

      match /assetTransactions/{entryId} {
        allow read, create, update: if true;
        allow delete: if true;
      }
    }
  }
}
