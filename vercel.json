{
  "fluid": true,
  "functions": {
    "api/cron-daily-update.ts": {
      "maxDuration": 120
    },
    "api/cron-daily-rescue.ts": {
      "maxDuration": 120
    },
    "api/update-prices.ts": {
      "maxDuration": 60
    },
    "api/manual-capture-snapshot.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron-daily-update",
      "schedule": "0 22 * * *"
    },
    {
      "path": "/api/cron-daily-rescue",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron-monthly-analysis",
      "schedule": "0 0 1 * *"
    },
    {
      "path": "/api/cron-quarterly-report",
      "schedule": "0 1 1 1,4,7,10 *"
    }
  ]
}
