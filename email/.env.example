# App
APP_TIMEZONE=Asia/Hong_Kong
LOG_LEVEL=INFO
DATA_DIR=var
OUTPUT_DIR=var/output
STATE_DB_PATH=var/state.sqlite3
DIGEST_BACKUP_DIR=var/output/digests
DISABLE_EMAIL_SEND=false

# Outlook / Microsoft Graph
OUTLOOK_SENDER_EMAIL=your_hotmail_or_outlook_address@hotmail.com
DIGEST_RECIPIENT_EMAIL=your_hotmail_or_outlook_address@hotmail.com
SOURCE_SENDER_EMAIL=kenjiosone@substack.com
SOURCE_SENDER_NAME=Kenji San from Kenji's Substack
MS_GRAPH_TENANT_ID=consumers
MS_GRAPH_CLIENT_ID=your_graph_app_client_id
MS_GRAPH_CLIENT_SECRET=your_graph_app_client_secret
MS_GRAPH_REFRESH_TOKEN=your_refresh_token
MS_GRAPH_SCOPE=offline_access https://graph.microsoft.com/Mail.Read https://graph.microsoft.com/Mail.Send https://graph.microsoft.com/User.Read
MS_GRAPH_BASE_URL=https://graph.microsoft.com/v1.0

# LLM Provider
LLM_PROVIDER=gemini
LLM_API_KEY=your_gemini_api_key
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta
LLM_MODEL=gemini-3.1-pro-preview
LLM_TIMEOUT_SECONDS=90
LLM_MAX_CHUNK_CHARS=12000
