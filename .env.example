VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id
VITE_PORTFOLIO_ACCESS_CODE=your_shared_access_code
PORTFOLIO_ACCESS_CODE=your_shared_access_code
# Server-side Firebase Admin auth for Vercel Functions:
# choose ONE of the following approaches
FIREBASE_ADMIN_SERVICE_ACCOUNT_JSON={"project_id":"your-project-id","client_email":"firebase-adminsdk-xxx@your-project-id.iam.gserviceaccount.com","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n"}
# or use separate variables
FIREBASE_ADMIN_PROJECT_ID=your-project-id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project-id.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# Optional override for the read-only Crypto month-log sync. If omitted, the
# Firebase Admin service account above is reused and must be shared on the
# Google Sheet as Viewer (not Editor).
CRYPTO_SHEET_SERVICE_ACCOUNT_JSON={"client_email":"sheet-reader@your-project-id.iam.gserviceaccount.com","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n"}
CRYPTO_SHEET_SPREADSHEET_ID=1CrXqZtK2Qy2rivBTN1BZTSbNpAY0Y5P6Rzsg8_OaaI4
CRYPTO_SHEET_SOURCE_RANGE='月結記錄'!A1:S500
GEMINI_API_KEY=your_gemini_api_key
GEMINI_EXTRACT_MODEL=gemini-2.5-flash-lite
GEMINI_ANALYZE_MODEL=gemini-2.5-pro
COINGECKO_API_KEY=your_coingecko_demo_key
